<UserControl x:Class="DiGi.UI.WPF.Controls.VisualBackgroundTasksControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DiGi.UI.WPF.Controls"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="400" d:DesignWidth="500">
    <Grid Background="#FFE5E5E5">
        <DataGrid ItemsSource="{Binding VisualBackgroundTasks, ElementName=Root}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  SelectionUnit="FullRow" 
                  SelectionMode="Single" 
                  HeadersVisibility="Column">
            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black" />
            </DataGrid.Resources>
            <DataGrid.Columns>

                <DataGridTextColumn Header="Task Name" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="ToolTip" Value="{Binding Description}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="ToolTip" Value="{Binding ExceptionText}" />
                            <Style.Triggers>
                                <Trigger Property="ToolTip" Value="{x:Null}">
                                    <Setter Property="ToolTipService.IsEnabled" Value="False" />
                                </Trigger>
                                <Trigger Property="ToolTip" Value="">
                                    <Setter Property="ToolTipService.IsEnabled" Value="False" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Action" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding ToggleText}" 
                                    Command="{Binding ToggleCommandAsync}"
                                    IsEnabled="{Binding CanToggle}"
                                    Margin="2,2,2,2" 
                                    HorizontalAlignment="Center" 
                                    MinWidth="80" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>